# ──────────────────────────────────────────────────
# PRODUCTION .env — скопируй в .env и заполни значения
# НИКОГДА не коммить .env в git!
# ──────────────────────────────────────────────────

# База данных
DB_HOST=localhost
DB_PORT=5432
DB_USER=dkstu_user
DB_PASSWORD=ЗАМЕНИ_НА_СЛОЖНЫЙ_ПАРОЛЬ_БД
DB_NAME=dkstu_personal_account

# Сервер
PORT=3000

# JWT — ОБЯЗАТЕЛЬНО замени на случайную строку длиной 64+ символа
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ЗАМЕНИ_НА_СЛУЧАЙНУЮ_СТРОКУ_64_СИМВОЛА
JWT_EXPIRES_IN=7d

# CORS — домен фронтенда в проде (без слеша в конце)
CORS_ORIGIN=https://твой-домен.ru
